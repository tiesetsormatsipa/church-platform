NODE_ENV=production
PORT=4000
FRONTEND_URL=https://truthofgod.techtursolutions.com
NEXT_PUBLIC_SITE_URL=https://truthofgod.techtursolutions.com
NEXT_PUBLIC_API_URL=https://truthofgod.techtursolutions.com
NEXT_PUBLIC_SOCKET_URL=wss://truthofgod.techtursolutions.com

DATABASE_URL="postgresql://church_user:CHANGE_ME@localhost:5432/church_platform?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=CHANGE_ME_WITH_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=CHANGE_ME_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://truthofgod.techtursolutions.com/api/v1/auth/google/callback
NEXTAUTH_URL=https://truthofgod.techtursolutions.com
NEXTAUTH_SECRET=CHANGE_ME_WITH_OPENSSL_RAND_BASE64_64

STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=/var/www/truthofgod/media
STORAGE_PUBLIC_URL=/media

EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@truthofgod.techtursolutions.com
EMAIL_FROM_NAME="Truth of God"

DEFAULT_TENANT_SLUG=main-church
ANALYTICS_ENABLED=false
POPIA_CONTACT_EMAIL=privacy@truthofgod.techtursolutions.com
DATA_RETENTION_DAYS=2555
LOG_LEVEL=info
LOG_FILE=/var/www/truthofgod/logs/api.log
