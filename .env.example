# ============================================================
# Church Platform — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Database ----
POSTGRES_DB=church_platform
POSTGRES_USER=church_user
POSTGRES_PASSWORD=church_secret
DATABASE_URL="postgresql://church_user:church_secret@localhost:5432/church_platform?schema=public"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ---- JWT ----
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Google OAuth ----
# Create credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---- NextAuth (frontend) ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# ---- Storage ----
# Default is local VPS filesystem storage. Keep /var/www/truthofgod/media backed up.
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./storage/media
STORAGE_PUBLIC_URL=/media

# ---- Email (adapter interface — not wired to live provider yet) ----
# Set EMAIL_PROVIDER to 'smtp', 'sendgrid', 'ses', 'resend', etc.
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@church.org
EMAIL_FROM_NAME="Church Platform"

# ---- MinIO (local S3) ----
MINIO_ROOT_USER=church_admin
MINIO_ROOT_PASSWORD=church_minio_secret

# ---- Default Tenant ----
DEFAULT_TENANT_ID=main-church
DEFAULT_TENANT_SLUG=main-church

# ---- PWA / Notifications ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ---- Analytics (hooks — not connected) ----
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=internal

# ---- Compliance ----
POPIA_CONTACT_EMAIL=privacy@church.org
DATA_RETENTION_DAYS=2555

# ---- Rate limiting ----
RATE_LIMIT_SHORT_TTL=1000
RATE_LIMIT_SHORT_MAX=10
RATE_LIMIT_AUTH_MAX=5

# ---- Logging ----
LOG_LEVEL=debug
LOG_FILE=logs/combined.log

# ---- API URLs (frontend) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:4000
